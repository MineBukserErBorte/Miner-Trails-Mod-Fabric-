{
	"schemaVersion": 1,
	"id": "trail-mod",
	"version": "${version}",
	"name": "Trail mod",
	"description": "Leaves a trail where ever you go!",
	"authors": [
		"MySocksAreGone"
	],
	"contact": {
		"homepage": "https://fabricmc.net/",
		"sources": "https://github.com/FabricMC/fabric-example-mod"
	},
	"license": "CC0-1.0",
	"icon": "assets/trail-mod/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"com.example.TrailMod"
		],
		"client": [
			"com.example.TrailModClient"
		]
	},
	"mixins": [
		"trail-mod.mixins.json",
		{
			"config": "trail-mod.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.19.3",
		"minecraft": "~1.21.11",
		"java": ">=21",
		"fabric-api": "*"
	}
}